#Global defaults for all ssh connections
Host *
    AddKeysToAgent yes # Enter passphrase only once per session
    UseKeychain yes   # macOS only
    IdentityFile ~/.ssh/id_ed25519
    ServerAliveInterval 60 # ping every 60 seconds, keep connection alive (prevent dropping by firewall or router)
    ServerAliveCountMax 2 # if server does not respond after 2 keep alive pings disconnect
# Re-direct github to port 443 as port 22 is blocked on the Infinity captive portal
Host github.com
  Hostname ssh.github.com
  Port 443
  User git
# ssh connection with the pi
Host pi
  Hostname 192.168.2.2
  User devdk
