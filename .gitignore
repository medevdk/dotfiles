# Ignore all
*

# But allow
!.gitignore
!stow.md
!README.md

# Git
!git/
!git/.gitconfig
!git/.gitignore_global

# Zsh
!zsh/
!zsh/.zshrc
!zsh/.fzf.zsh
!zsh/.zshenv
!zsh/.zsh_plugins.txt

# Vim
!vim/
!vim/.vimrc

# Tmux
!.tmux/
!.tmux/.tmux.conf

# SSH
!ssh/
!ssh/.ssh/
!ssh/.ssh/config

# Shared config
!shared/
!shared/.ansiweatherrc
!shared/.config/
!shared/.config/mpv/
!shared/.config/mpv/**
!shared/.config/bat/
!shared/.config/bat/**
!shared/.config/cmus/
!shared/.config/cmus/**
!shared/.config/neofetch/
!shared/.config/neofetch/**
!shared/.config/nvim/
!shared/.config/nvim/**
!shared/.config/wezterm/
!shared/.config/wezterm/**
!shared/.config/yt-dlp/
!shared/.config/yt-dlp/**
!shared/.config/fish/
!shared/.config/fish/**
!shared/.config/gh/
!shared/.config/gh/**

# Yazi (shared)
!yazi/
!yazi/**
yazi/.DS_Store
yazi/flavors/.DS_Store
yazi/plugins/.DS_Store

# Mac specific
!mac/
!mac/.config/
!mac/.config/aerospace/
!mac/.config/aerospace/**
!mac/.config/iterm2/
!mac/.config/iterm2/**
!mac/.config/sketchybar/
!mac/.config/sketchybar/**
!mac/brew/
!mac/brew/leaves.txt
!mac/brew/casks.txt

# Linux specific
!linux/
!linux/.config/
!linux/.config/sway/
!linux/.config/sway/**
!linux/.config/waybar/
!linux/.config/waybar/**
!linux/.config/wlogout/
!linux/.config/wlogout/**
!linux/.config/wofi/
!linux/.config/wofi/**
!linux/.config/zathura/
!linux/.config/zathura/**
!linux/.config/foot/
!linux/.config/foot/**

# Global DS_Store exclusion
**/.DS_Store
